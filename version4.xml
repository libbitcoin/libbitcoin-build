  <canonical>
    <language id="c" cmake="C">
      <sources suffix="c" />
      <headers suffix="h" />
    </language>
    <language id="c++" cmake="CXX">
      <sources suffix="cpp" />
      <headers suffix="hpp" />
      <headers suffix="ipp" />
    </language>

    <compiler standard="20">
        <flag id="Wall"
          comment="Enable questionable/easy to avoid error warnings."
          type="private">
          <symbol value="-Wall" />
          <context language="c" />
          <context language="c++" />
        </flag>
        <flag id="Wextra"
          comment="Enables extra warnings not enabled by -Wall."
          type="private">
          <symbol value="-Wextra" />
          <context language="c" />
          <context language="c++" />
        </flag>
        <flag id="Wpedantic"
          comment="Enables all warnings demanded by strict ISO C/C+."
          type="private">
          <symbol value="-Wpedantic" />
          <context language="c" />
          <context language="c++" />
        </flag>
        <flag id="Wno-reorder"
          comment="Disallow warning on style order of declarations."
          type="private">
          <symbol value="-Wno-reorder" />
          <context language="c++" />
        </flag>
        <flag id="Wno-missing-field-initializers"
          comment="Suppress warning for incomplete field initialization."
          type="private">
          <symbol value="-Wno-missing-field-initializers" />
          <context language="c++" />
        </flag>
         <flag id="Wno-missing-braces"
          comment="Conform to style."
          type="private">
          <symbol value="-Wno-missing-braces" />
          <context language="c++" />
        </flag>
         <flag id="Wno-comment"
          comment="Ignore comments within comments or commenting of backslash extended lines."
          type="private">
          <symbol value="-Wno-comment" />
          <context language="c++" />
        </flag>
         <flag id="Wno-deprecated-copy"
          comment="Suppress warning for copy of implicitly generated copy constructor."
          type="private">
          <symbol value="-Wno-deprecated-copy" />
          <context language="c++" />
        </flag>
         <flag id="Wno-ignored-attributes"
          comment="Suppress warning for ignored attributes (arising on template arguments)."
          type="private">
          <symbol value="-Wno-ignored-attributes" />
          <context language="c++" />
        </flag>
         <flag id="Wno-mismatched-tags"
          comment="Conflict in stdlib under clang."
          type="private"
          compiler="clang">
          <symbol value="-Wno-mismatched-tags" />
          <context language="c++" />
        </flag>
         <!-- This varies by dependency build, such as boost. So we do not enforce. -->
        <flag id="fvisibility=hidden"
          comment="Hide internal functions from external libs."
          type="private"
          compiler="gnu">
          <symbol value="-fvisibility=hidden" />
          <context language="c++" />
        </flag>
        <flag id="Wno-long-long"
          comment="Allow use of C99 'long long' type."
          type="private">
          <symbol value="-Wno-long-long" />
          <context language="c++" />
        </flag>
         <flag id="fno-var-tracking-assignments"
          comment="Limit delays and warnings."
          type="private"
          compiler="gnu">
          <symbol value="-fno-var-tracking-assignments" />
          <context language="c++" />
        </flag>
        <flag id="fstack-protector"
          comment="Protect stack."
          type="private">
          <symbol value="-fstack-protector" />
        </flag>
        <flag id="fstack-protector-all"
          comment="Protect stack comprehensively." 
          type="private">
          <symbol value="-fstack-protector-all" />
        </flag>

        <!-- macos active between clang 13-16, deprecated 17, removed 18 -->
        <link id="no_fixup_chains"
          comment="Address -undefined dynamic_lookup MacOS error."
          type="private">
          <symbol value="-no_fixup_chains" />
        </link>
     </compiler>
 </canonical>

