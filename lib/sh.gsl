###############################################################################

###############################################################################
# Functions
###############################################################################

function global.shebang(interpreter)
    write_line("#!/bin/$(my.interpreter)")
endfunction

.endtemplate
.template 1
.
.##############################################################################
.# Macros
.##############################################################################
.
.macro global.copyleft(name)
###############################################################################
#  Copyright (c) 2014-2026 $(my.name) developers (see COPYING).
#
#         GENERATED SOURCE CODE, DO NOT EDIT EXCEPT EXPERIMENTALLY
#
###############################################################################
.endmacro
.
.macro global.heading1(text)

# $(my.text)
#==============================================================================
.endmacro
.
.macro global.heading2(text)

# $(my.text)
#------------------------------------------------------------------------------
.endmacro
.
.macro global.heading3(text)
# $(my.text)
.endmacro
.
.macro global.define_display_functions()

display_heading_message()
{
    printf "\\n********************** %s **********************\\n" "$@"
}

display_message()
{
    printf "%s\\n" "$@"
}

display_message_verbose()
{
    if [[ -v DISPLAY_VERBOSE ]] && [[ "${DISPLAY_VERBOSE}" == "yes" ]]; then
        display_message "$@"
    fi
}

display_error()
{
    >&2 printf "%s\\n" "$@"
}
.endmacro
.
.macro global.define_directory_functions()

create_directory()
{
    local DIRECTORY="$1"
    local MODE="$2"

    if [[ -d "${DIRECTORY}" ]]; then
        if [[ ${MODE} == "-f" ]]; then
            display_message "'${DIRECTORY}' reinitializing..."
            rm -rf "${DIRECTORY}"
            mkdir -p "${DIRECTORY}"
        else
            display_message "'${DIRECTORY}' exists, reusing..."
        fi
    else
        display_message "'${DIRECTORY}' initializing..."
        mkdir -p "${DIRECTORY}"
    fi
}

force_create_directory()
{
    create_directory "$@" -f
}

pop_directory()
{
    popd >/dev/null
}

push_directory()
{
    local DIRECTORY="$1"
    pushd "${DIRECTORY}" >/dev/null
}

remove_directory_force()
{
    rm -rf "$@"
}
.endmacro
.
.macro global.initialize_environment()

OPTS_ENABLE="set -eo pipefail"
OPTS_DISABLE="set +e"

eval "${OPTS_ENABLE}"
trap 'echo "FATAL ERROR: Command failed at line ${LINENO}: ${BASH_COMMAND}" >&2' ERR
.endmacro
.
.macro global.define_error_functions()

enable_error_on_exit()
{
    eval "${OPTS_ENABLE}"
}

disable_error_on_exit()
{
    eval "${OPTS_DISABLE}"
}
.endmacro
.
.endtemplate

